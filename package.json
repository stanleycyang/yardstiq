{
  "name": "yardstiq",
  "version": "0.1.0",
  "description": "Side-by-side AI model comparison CLI",
  "type": "module",
  "bin": {
    "yardstiq": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "files": [
    "dist/",
    "benchmarks/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "llm",
    "cli",
    "comparison",
    "diff",
    "terminal"
  ],
  "author": "Stanley Yang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stanleycyang/aidiff.git"
  },
  "homepage": "https://github.com/stanleycyang/aidiff",
  "bugs": {
    "url": "https://github.com/stanleycyang/aidiff/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.49",
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/openai": "^3.0.36",
    "ai": "^6.0.104",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.0",
    "ink": "^6.8.0",
    "ollama-ai-provider": "^1.2.0",
    "react": "^19.2.4",
    "ulid": "^3.0.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
